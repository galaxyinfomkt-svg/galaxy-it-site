# ============================================
# Galaxy IT — n8n Configuration
# Copy this file to .env and fill in the values
# cp .env.example .env && nano .env
# ============================================

# n8n Domain (without https://)
N8N_HOST=n8n.galaxyinfo.us

# n8n Admin Login
N8N_USER=admin
N8N_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=CHANGE_THIS_RUN_openssl_rand_hex_32

# Anthropic API Key (for Claude AI)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXX

# Team Notifications
TEAM_EMAIL=info@galaxyinfo.us
LUIZ_EMAIL=luiz@galaxyinfo.us
LUIZ_PHONE=+15084999279

# Twilio (optional — for SMS notifications)
# Get yours at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
